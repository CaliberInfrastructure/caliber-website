# ─────────────────────────────────────────────────────────────
# Repo scope
# This git repo (CaliberInfrastructure/caliber-website) lives inside the
# "Caliber Agency Files" business folder, but only the website app in
# caliber-ai-infrastructure/ belongs here. Ignore everything else at the
# repo root — business docs, other project folders, scratch/lock files —
# so non-website files never get committed into the website repo again.
# ─────────────────────────────────────────────────────────────
/*
!/.gitignore
!/caliber-ai-infrastructure/

# ── Standard ignores (apply within caliber-ai-infrastructure/) ──

# Dependencies
node_modules

# Build output
dist
dist-ssr

# Environment files
*.local
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Claude
.claude/
.vercel
.env*.local
